{
  "name": "frontend",
  "version": "1.0.0",
  "description": "TREDO Cockpit autonomous trading client",
  "author": "Operator",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "main-electron.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "cap:init": "cap init",
    "cap:sync": "cap sync android",
    "cap:open": "cap open android",
    "build:android": "npm run build && npx cap sync",
    "test": "vitest run",
    "test:watch": "vitest",
    "desktop:dev": "electron .",
    "desktop:build:linux": "electron-builder --linux AppImage --x64",
    "desktop:build:mac": "electron-builder --mac zip --arm64"
  },
  "dependencies": {
    "@capacitor/core": "^6.0.0",
    "clsx": "^1.2.1",
    "jotai": "^2.2.0",
    "lightweight-charts": "^5.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^1.13.0"
  },
  "devDependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/cli": "^8.3.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.14",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "jsdom": "^29.1.1",
    "postcss": "^8.4.24",
    "tailwindcss": "^3.3.2",
    "typescript": "^5.0.2",
    "vite": "^5.4.15",
    "vitest": "^4.1.7"
  },
  "build": {
    "electronVersion": "42.2.0",
    "appId": "com.tredo.cockpit",
    "productName": "TREDO Cockpit",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "main-electron.cjs",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility"
    },
    "mac": {
      "target": [
        "zip"
      ]
    }
  }
}
