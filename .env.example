# ── ARKM System Production Environment Configuration ───────────────────────

# Gateway & Ports
PORT=8080
HOST=0.0.0.0

# LLM Providers (Google Gemini Intelligence)
# ⚠️  IMPORTANT: NEVER commit real API keys to version control!
# Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Databases & Cache Config
# Production uses Postgres and Redis; fallback uses SQLite checkpointer
DATABASE_URL=postgres://sethu_operator:operator_secure_password_99@postgres:5432/arkm_vault
REDIS_URL=redis://redis:6379

# Exchange Credentials (Binance + KuCoin credentials)
BINANCE_API_KEY=your_binance_api_key
BINANCE_SECRET_KEY=your_binance_secret_key
KUCOIN_API_KEY=your_kucoin_api_key
KUCOIN_SECRET_KEY=your_kucoin_secret_key

# Tantra Safety Coordinator settings
LOG_LEVEL=info
SLACK_WEBHOOK_URL=
EMAIL_NOTIFICATIONS_ENABLED=false
