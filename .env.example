# ── TREDO System Production Environment Configuration ───────────────────────

# === CRITICAL: NEVER commit real keys to git ===

# Server
HOST=0.0.0.0
PORT=8080

# Trading / Security
JWT_SECRET=your_super_secret_jwt_key_here_make_it_long_and_random

# Databases & Cache Config
# Production uses Postgres and Redis; fallback uses SQLite checkpointer
DATABASE_URL=postgres://sethu_operator:operator_secure_password_99@postgres:5432/tredo_vault
REDIS_URL=redis://redis:6379

# Exchange Credentials (Binance + KuCoin credentials)
